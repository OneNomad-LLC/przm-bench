{
  "name": "@onenomad/przm-bench",
  "version": "0.1.0",
  "description": "Reference implementation of the przm benchmark suite — multi-agent convergence, AI memory recall, and more. Vendor-neutral, signed Ed25519 receipts, deterministic scoring. Methodology canonical at https://przm.sh/methodology.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "przm-bench": "dist/cli.js"
  },
  "files": [
    "dist",
    "fixtures",
    "keys/receipt-signing.pub",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneNomad-LLC/przm-bench.git"
  },
  "homepage": "https://przm.sh",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test src/**/*.test.ts",
    "bench": "node --import tsx src/cli.ts run",
    "verify": "node --import tsx src/cli.ts verify",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@onenomad/engram-mcp": "^2.4.0",
    "better-sqlite3": "^12.10.0",
    "compromise": "^14.15.0",
    "mem0ai": "^3.0.3",
    "natural": "^8.1.1",
    "ollama": "^0.5.18",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "mem0ai": {
      "@anthropic-ai/sdk": "$@anthropic-ai/sdk"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "przm",
    "benchmark",
    "ai",
    "ai-reliability",
    "multi-agent",
    "convergence",
    "sycophancy",
    "memory",
    "mcp",
    "engram",
    "mem0",
    "letta",
    "zep",
    "crewai",
    "autogen",
    "langgraph",
    "signed-receipts",
    "ed25519",
    "reproducible"
  ]
}
